# .env.example
# Kopiere diese Datei zu .env.local und trage die Werte ein
# NIEMALS .env.local in Git committen!

# Google Sheets API — Service Account
# Die service-account.json Datei muss im Projekt-Root liegen (NICHT in Git!)
# Alternativ als Umgebungsvariablen für Vercel:
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
